manifest {
    author = 'Nicolas Chiaruttini'
    description = 'Pipeline for CZI processing with BigStitcher and BrainReg'
    version = '0.1.0-SNAPSHOT'
}

params {
    // Default for local development
    fiji_cache_dir = "${projectDir}/work/fiji_mouse_czi_processing"
    env_cache_dir = "${projectDir}/work/envs"
    atlas_cache_dir = "${projectDir}/work/atlas"

    input = null  // Will be overridden by command line

    // SSH connection and data layout
    ssh_host = "lmsmith@haas056.rcp.epfl.ch"
    input_base_path = "/mnt/lsens-data"        // Root of input data tree
    output_base_path = "/mnt/lsens-analysis"    // Root of output/analysis tree
    user_name = null    // Required for output publishing, e.g. "Lana_Smith"
    brain_id = null     // Shorthand input, e.g. "MS181" or "MS181,LS010"
    dry_run = false     // If true, print resolved paths and exit without processing
    check_voxels = false // If true, stage files and extract original voxel sizes, then exit
    fusion_only = false  // If true, stop after fusion (skip brainreg and registration)

    // Max number of concurrent haas<->cluster transfers (stage/publish/copy steps).
    // 1 = serialize them (avoids bandwidth/disk contention to the SMB share).
    max_concurrent_transfers = 1

    // OME-Zarr conversion of ch1 (disabled by default, enable with --export_ome_zarr)
    export_ome_zarr = false
    ome_zarr_output_base = "/work/lsens"

    bigstitcher {
        
        channel_alignment {
            pairwise_shifts_downsamples {
                x = 4
                y = 4
                z = 2
            }
            filter_min_r = 0.7
        }
        
        tile_alignment {
            use_channel = 0
            pairwise_shifts_downsamples {
                x = 4
                y = 4
                z = 2
            }
            filter_min_r = 0.7
        }
        
        icp_refinement {
            icp_refinement_type = "Simple (all together)"
            downsampling = "Downsampling 8/8/4"
            interest = "Average Threshold"
            icp_max_error = "Normal Adjustment (<5px)"
        }
        
        reorientation {
            raw_orientation = "IPR"
            reorient_to_asr = false
        }
        
        fusion_config {
            downsample=1
            fusion_method = "SMOOTH AVERAGE"
        }
    }

    brainreg {
        // Single valued parameters
        atlas = "perens_lsfm_mouse_20um"
        backend = "niftyreg"
        channel_used_for_registration = 0
        affine_n_steps = 6
        affine_use_n_steps = 5
        freeform_n_steps = 6
        freeform_use_n_steps = 4
        smoothing_sigma_reference = -1.0
        histogram_n_bins_floating = 128
        histogram_n_bins_reference = 128
        n_free_cpus = 2
        debug = false
        save_original_orientation = true
        brain_geometry = "full"
        sort_input_file = true
        pre_processing = "default"

        // Sweepable parameters. Use one value and keep brackets if you don't want to sweep
        // It's possible to transfer other parameters to sweepable ones but this requires changes in the code
        bending_energy_weight = [0.7, 0.8, 0.9] // Sweepable
        grid_spacing = [-20,-30] // Sweepable  
        smoothing_sigma_floating = ['-1'] //Sweepable
    }

}

profiles {
    local {
        params {
            fiji_cache_dir = "${projectDir}/work/fiji_mouse_czi_processing"
        }
        apptainer.enabled = true
        apptainer.autoMounts = true
        process.executor = 'local'
        
        // Set cache directory to avoid the warning
        apptainer.cacheDir = "$HOME/.apptainer/cache"
    }
    
    slurm {
        process {
            executor = 'slurm'
            queue = 'standard'
            memory = '64 GB'
            cpus = 16
            time = '4h'
            
            withName: 'stageFilesRSync|publishInitialXmlToSource|publishStitchedXmlToSource|publishOmeZarr|copyResultsToImageFolder' {
                executor = 'local'  // Explicit override
                memory = '2 GB'
                cpus = 1
            }

            // Serialize haas<->cluster transfers (one file at a time) to avoid
            // bandwidth/disk contention on the SMB share. Tune with
            // --max_concurrent_transfers (default 1).
            withName: 'stageFilesRSyncSSH|stageFusedCh1|publishInitialXmlToSource|publishStitchedXmlToSource|publishFusedChannelsToSource|copyResultsToImageFolder' {
                maxForks = params.max_concurrent_transfers
            }

            // Heavy fused-channel uploads run on a compute node (not the busy
            // login node) for far better network throughput.
            withName: 'publishFusedChannelsToSource' {
                executor = 'slurm'
                queue = 'standard'
                cpus = 2
                memory = '8 GB'
                time = '12h'
            }

            withName: 'alignChannelsWithBigstitcher|alignTilesWithBigstitcher|fuseBigStitcherDataset|convertTiffToOmeZarr' {
                executor = 'slurm'  // Explicitly set executor
                queue = 'bigmem'
                memory = '480 GB'
                cpus = 40
                time = '8h'
            }

            withName: 'icpRefinementWithBigstitcher' {
                executor = 'slurm'
                queue = 'standard'
                memory = '96 GB'
                time = '12h'
            }

            withName: 'brainregRunRegistration' {
                executor = 'slurm'
                queue = 'bigmem'
                memory = '150 GB'
                cpus = 32
                time = '8h'
            }
        }
       
        workDir = "/scratch/${System.getProperty('user.name')}/nf"
        apptainer.enabled = true
        apptainer.autoMounts = true
        apptainer.cacheDir = "/work/${['id', '-gn'].execute().text.trim().replaceAll('-unit$', '')}/apptainer_cache" // you can replace ${['id', '-gn'].execute().text.trim().replaceAll('-unit$', '')} with the name of your group if this does not work (for instance ptbiop afaiac)
       
        params {
            fiji_cache_dir = "/work/${['id', '-gn'].execute().text.trim().replaceAll('-unit$', '')}/fiji_mouse_czi_processing"
            env_cache_dir = "/work/${['id', '-gn'].execute().text.trim().replaceAll('-unit$', '')}/envs"
            atlas_cache_dir = "/work/${['id', '-gn'].execute().text.trim().replaceAll('-unit$', '')}/atlas"
        }
    }

    test {
        params.input = "${projectDir}/test_data/Small.czi" // This file is located here and has been renamed: https://zenodo.org/records/8305531/files/Demo%20LISH%204x8%2015pct%20647.czi
        params.bigstitcher.channel_alignment.filter_min_r = 0.5
    }
}

env {
  FIJI_PATH = '/path/to/your/Fiji.app'
}
